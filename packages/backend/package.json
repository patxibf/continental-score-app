    "resend": "^6.9.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.17",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^5.9.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
